
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'hassandeeb473@gmail.com' || 
        request.auth.token.email == 'HassanDeeb@example.com'
      );
    }

    match /users/{userId}/profile/{profileId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }

    match /tradingSignals/{signalId} {
      allow read: if isSignedIn(); 
      allow write: if isAdmin();
    }
    
    match /manualSignals/{signalId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /users/{userId}/signalHistory/{historyId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    match /{path=**} {
      allow read, write: if isAdmin();
    }
  }
}
